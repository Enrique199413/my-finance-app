rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to completely manage their own profile and keys
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Other family members might need to read the public key to wrap the vault key
      allow read: if request.auth != null; 
    }

    // Vault Escrow System Security (E2EE)
    // - Only the specific recipient can READ their own envelope key
    // - Any authenticated family member can WRITE/approve an envelope key
    match /families/{familyId}/escrow/{memberId} {
      allow read: if request.auth != null && request.auth.uid == memberId;
      allow write: if request.auth != null; 
    }

    // Family and general subcollections fallback
    // Since this is a personal app, family members are trusted with each other's data
    match /families/{familyId} {
      allow read, write: if request.auth != null;
    }
    
    match /families/{familyId}/{document=**} {
      // Prevent wildcards from overriding the escrow rules
      // Escrow rules take precedence according to subcollections hierarchy.
      allow read, write: if request.auth != null;
    }

    // General fallback for unmanaged routes
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
